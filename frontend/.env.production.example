# ── Production Environment Variables for Vercel ──────────────────

# ── NextAuth (REQUIRED) ───────────────────────────────────────────
# Your Vercel deployment URL
NEXTAUTH_URL=https://your-project-name.vercel.app

# Generate with: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your-32-character-random-secret-here

# ── Keycloak OIDC (REQUIRED for Authentication) ───────────────────
# Your Keycloak server URL
KEYCLOAK_ISSUER=https://your-keycloak-server.com/realms/cashflow
KEYCLOAK_CLIENT_ID=cashflow-api
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret

# ── Backend API URLs (REQUIRED) ───────────────────────────────────
# Your production backend API
NEXT_PUBLIC_API_BASE_URL=https://api.tadfuq.com
NEXT_PUBLIC_INGESTION_API_BASE_URL=https://ingestion.tadfuq.com

# ── Optional Settings ─────────────────────────────────────────────
# Set to false in production
NEXT_PUBLIC_ENABLE_MOCKS=false
NEXT_PUBLIC_DEV_SKIP_AUTH=false

# ── Instructions ──────────────────────────────────────────────────
# 1. Copy these variables to Vercel Dashboard
# 2. Go to: Settings → Environment Variables
# 3. Add each variable with its value
# 4. Select "Production" environment
# 5. Click "Save"
# 6. Redeploy your project

# For detailed instructions, see: VERCEL_ENV_SETUP.md
